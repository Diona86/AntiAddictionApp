<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5F9">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvChartSwitchLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stat_chart_switch_label"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/scrollChartChildFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupChartChild"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:selectionRequired="true"
                    app:singleSelection="true" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvChartScopeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#5C5F7A"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App 使用占比"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="注：小于 1 分钟的应用不展示"
                android:textColor="#8A8A8A"
                android:textSize="11sp" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieAppUsage"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="今日使用趋势"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineTodayTrend"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:id="@+id/blockWeekTrend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="近 7 天趋势"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineWeekTrend"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvWeekSupervisorNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/stat_week_supervisor_note"
                android:textColor="#8A8A8A"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="应用使用明细"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mainRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:padding="8dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/statLoadingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80F2F5F9"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="加载统计中..."
            android:textColor="#666666"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>